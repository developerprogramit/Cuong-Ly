  <script>
    /* ===============================
       1) INTRO: khóa scroll 2.3s
       =============================== */
    window.addEventListener("DOMContentLoaded", () => {
      document.body.classList.add("intro-play");

      setTimeout(() => {
        document.body.classList.remove("no-scroll");
        document.body.classList.add("intro-done");
        flushPendingReveals();
      }, 2300);
    });

    /* =====================================
       2) Scroll reveal: tới đâu hiện tới đó
          - Nếu intro chưa xong: giữ pending
       ===================================== */
    const pending = new Set();

    function applyReveal(el){
      const delay = el.dataset.delay ? parseInt(el.dataset.delay, 10) : 0;
      el.style.transitionDelay = delay + "ms";
      el.classList.add("in");
    }

    function flushPendingReveals(){
      pending.forEach(el => applyReveal(el));
      pending.clear();
    }

    const io = new IntersectionObserver((entries)=>{
      entries.forEach(e=>{
        if(!e.isIntersecting) return;

        // intro chưa xong -> pending
        if(!document.body.classList.contains("intro-done")){
          pending.add(e.target);
          return;
        }

        applyReveal(e.target);
        io.unobserve(e.target); // animate 1 lần
      })
    },{
      threshold: 0.14,
      rootMargin: "0px 0px -8% 0px"
    });

    document.querySelectorAll(".reveal").forEach(el => io.observe(el));

    /* ===============================
       3) Menu overlay
       =============================== */
    const overlay = document.getElementById('overlay');
    document.getElementById('btnMenu').addEventListener('click', ()=> overlay.classList.toggle('open'));
    overlay.addEventListener('click', (e)=>{ if(e.target === overlay) overlay.classList.remove('open'); });
    document.querySelectorAll('[data-close]').forEach(a => a.addEventListener('click', ()=> overlay.classList.remove('open')));

    /* ===============================
       4) Map
       =============================== */
    function openMap(query){
      const url = "https://maps.app.goo.gl/6CaqXjwzhEevhPjB8";
      window.open(url, "_blank");
    }
    window.openMap = openMap;

    /* ===============================
       5) Countdown (đổi ngày ở đây)
       =============================== */
    const weddingTime = new Date("2026-02-28T08:00:00+07:00").getTime();
    const $d=document.getElementById('d');
    const $h=document.getElementById('h');
    const $m=document.getElementById('m');
    const $s=document.getElementById('s');

    function tick(){
      const now = Date.now();
      let diff = Math.max(0, weddingTime - now);
      const days = Math.floor(diff/(1000*60*60*24));
      diff %= (1000*60*60*24);
      const hours = Math.floor(diff/(1000*60*60));
      diff %= (1000*60*60);
      const mins = Math.floor(diff/(1000*60));
      diff %= (1000*60);
      const secs = Math.floor(diff/1000);

      $d.textContent = days;
      $h.textContent = hours;
      $m.textContent = mins;
      $s.textContent = secs;
    }
    tick();
    setInterval(tick, 1000);

    /* ===============================
       6) Gallery slider (main + thumbs)
       =============================== */
    const images = [
      "https://images.unsplash.com/photo-1520854221256-17451cc331bf?q=80&w=1400&auto=format&fit=crop",
      "https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=1400&auto=format&fit=crop",
      "https://images.unsplash.com/photo-1544077960-604201fe74bc?q=80&w=1400&auto=format&fit=crop",
      "https://images.unsplash.com/photo-1491438590914-bc09fcaaf77a?q=80&w=1400&auto=format&fit=crop",
      "https://images.unsplash.com/photo-1504196606672-aef5c9cefc92?q=80&w=1400&auto=format&fit=crop",
      "https://images.unsplash.com/photo-1487412912498-0447578fcca8?q=80&w=1400&auto=format&fit=crop"
    ];

    const mainImg = document.getElementById('mainImg');
    const thumbs = document.getElementById('thumbs');
    const frameImg = document.getElementById('frameImg');
    let idx = 0;

    function renderThumbs(){
      thumbs.innerHTML = "";
      images.forEach((src,i)=>{
        const t = document.createElement('div');
        t.className = "thumb" + (i===idx ? " active" : "");
        const im = document.createElement('img');
        im.src = src;
        im.alt = "thumb " + (i+1);
        t.appendChild(im);
        t.addEventListener('click', ()=> setSlide(i));
        thumbs.appendChild(t);
      });
    }

    function setSlide(i){
      idx = (i + images.length) % images.length;
      mainImg.src = images[idx];
      frameImg.src = images[idx];
      renderThumbs();
    }

    document.getElementById('prev').addEventListener('click', ()=> setSlide(idx-1));
    document.getElementById('next').addEventListener('click', ()=> setSlide(idx+1));
    setSlide(0);

    /* Fullscreen modal */
    const modal = document.getElementById('modal');
    const modalImg = document.getElementById('modalImg');
    document.getElementById('fs').addEventListener('click', ()=>{
      modalImg.src = images[idx];
      modal.classList.add('open');
    });
    document.getElementById('closeModal').addEventListener('click', ()=> modal.classList.remove('open'));
    modal.addEventListener('click', (e)=>{ if(e.target===modal) modal.classList.remove('open'); });

    /* ===============================
       7) RSVP demo (lưu localStorage)
       =============================== */
    const submit = document.getElementById('submitRsvp');
    const msg = document.getElementById('rsvpMsg');
    submit.addEventListener('click', ()=>{
      const name = document.getElementById('guestName').value.trim();
      const count = document.getElementById('guestCount').value;
      const attend = [...document.querySelectorAll('input[name="attend"]')].find(x=>x.checked)?.value || "yes";

      if(!name){
        msg.textContent = "Vui lòng nhập họ và tên nhé 🙂";
        msg.style.color = "#b0182f";
        return;
      }

      const payload = { name, count, attend, at: new Date().toISOString() };
      localStorage.setItem("wedding_rsvp", JSON.stringify(payload));

      msg.textContent = "Đã ghi nhận! Cảm ơn bạn ❤️";
      msg.style.color = "#2b6b2e";
    });

    /* ===============================
       8) Music toggle
       =============================== */
    const btnMusic = document.getElementById('btnMusic');
    const bgm = document.getElementById('bgm');
    let playing = false;

    btnMusic.addEventListener('click', async ()=>{
      try{
        if(!playing){
          await bgm.play();
          playing = true;
          btnMusic.classList.add('is-playing');
        }else{
          bgm.pause();
          playing = false;
          btnMusic.classList.remove('is-playing');
        }
      }catch(err){
        alert("Muốn có nhạc: tạo file assets/music.mp3 (hoặc bật quyền phát âm thanh trên trình duyệt).");
      }
    });
  </script>
</body>
</html>
