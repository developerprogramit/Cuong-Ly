<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Thiệp cưới • Cường & Ly</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Alex+Brush&family=Great+Vibes&family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>
    :root{
      --bg:#f4f1ea;
      --bg2:#efece4;
      --paper:#f7f5ef;
      --text:#2d2d2d;
      --muted:#7a7a7a;
      --blue:#6f84b3;
      --blue2:#5f76a8;
      --olive:#6b6a3f;
      --shadow: 0 14px 40px rgba(0,0,0,.10);
      --shadow2: 0 10px 22px rgba(0,0,0,.08);
      --max: 430px;
    }

    *{ box-sizing:border-box; }
    html,body{ height:100%; }
    body{
      margin:0;
      color:var(--text);
      background:var(--bg);
      font-family:Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      overflow-x:hidden;
    }
    html.no-scroll, body.no-scroll{ overflow:hidden; height:100%; }

    /* ===== Layout center kiểu thiệp ===== */
    .page{
      width: min(100%, var(--max));
      margin: 0 auto;
      position: relative;
      min-height: 100vh;
      background: var(--bg);
    }
    section{ padding: 28px 18px; }
    .center{ text-align:center; }
    .muted{ color: var(--muted); }
    .sp8{ height:8px; }
    .sp14{ height:14px; }
    .divider{
      height: 10px;
      border-top: 3px dashed var(--blue);
      opacity: .6;
      margin: 18px 0 0;
    }

    /* ===== Watermark dọc giống ảnh (muốn bỏ: display:none) ===== */
    .wm{
      position: fixed;
      right: 10px;
      top: 50%;
      transform: translateY(-50%) rotate(-90deg);
      transform-origin: right center;
      font-size: 14px;
      color: #111;
      opacity: .65;
      letter-spacing:.3px;
      pointer-events:none;
      z-index: 20;
    }

    /* ===== Floating buttons ===== */
    .fab{
      position: fixed;
      z-index: 50;
      border: 0;
      width: 46px; height: 46px;
      border-radius: 999px;
      display:grid; place-items:center;
      box-shadow: var(--shadow2);
      cursor:pointer;
      -webkit-tap-highlight-color: transparent;
    }
    .fab:active{ transform: scale(.98); }

    .fab.music{
      left: 16px; top: 16px;
      background: radial-gradient(circle at 30% 30%, #ff8aa0, #d8576d);
      color: #fff;
    }
    .fab.menu{
      right: 16px; bottom: 18px;
      background: #ffffff;
      color: #111;
    }
    .icon-hamburger{ width: 18px; height: 12px; position: relative; }
    .icon-hamburger span{
      position:absolute; left:0; right:0; height:2px;
      background:#111; border-radius: 2px;
    }
    .icon-hamburger span:nth-child(1){ top:0; }
    .icon-hamburger span:nth-child(2){ top:5px; opacity:.9; }
    .icon-hamburger span:nth-child(3){ top:10px; opacity:.85; }

    .icon-play{
      width: 0; height: 0;
      border-left: 12px solid #fff;
      border-top: 8px solid transparent;
      border-bottom: 8px solid transparent;
      margin-left: 2px;
    }
    .music.is-playing .icon-play{
      width: 14px; height: 14px; margin-left:0;
      border:0;
      background: linear-gradient(90deg,#fff 0 40%, transparent 40% 60%, #fff 60% 100%);
      border-radius: 2px;
    }

    /* ===== Menu overlay ===== */
    .overlay{
      position: fixed; inset: 0;
      background: rgba(0,0,0,.35);
      backdrop-filter: blur(6px);
      opacity: 0; pointer-events:none;
      transition: .25s;
      z-index: 60;
    }
    .overlay.open{ opacity:1; pointer-events:auto; }
    .sheet{
      position: absolute;
      left: 50%; bottom: 14px;
      transform: translateX(-50%) translateY(18px);
      width: min(92vw, 420px);
      background: #fff;
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 14px;
      transition: .25s;
    }
    .overlay.open .sheet{ transform: translateX(-50%) translateY(0); }
    .sheet h4{ margin: 4px 8px 10px; font-size: 14px; color:#111; letter-spacing:.3px; }
    .nav{ display:grid; gap:10px; padding: 0 6px 10px; }
    .nav a{
      text-decoration:none; color:#111;
      background:#f5f5f5;
      border-radius: 12px;
      padding: 12px 12px;
      display:flex; align-items:center; justify-content:space-between;
      font-weight:700;
    }
    .nav a small{ font-weight:500; color:#666; }

    /* ===== Modal fullscreen ===== */
    .modal{
      position: fixed; inset:0;
      background: rgba(0,0,0,.85);
      display:none;
      z-index: 80;
      padding: 18px;
    }
    .modal.open{ display:flex; align-items:center; justify-content:center; }
    .modal img{
      width: min(96vw, 900px);
      height:auto;
      border-radius: 14px;
      box-shadow: 0 16px 50px rgba(0,0,0,.35);
    }
    .modal .close{
      position:absolute; top: 16px; right:16px;
      width: 44px; height: 44px;
      border-radius:999px;
      border:0;
      background: rgba(255,255,255,.14);
      color:#fff;
      font-size:18px;
      cursor:pointer;
    }

    /* =========================================================
       INTRO: mở vào hero hiện dần theo thứ tự + khóa scroll 2.3s
       ========================================================= */
    .intro-item{
      opacity:0;
      transform: translateY(18px);
      will-change: transform, opacity;
    }
    body.intro-play .intro-item{
      animation: introFadeUp 900ms cubic-bezier(.2,.85,.2,1) forwards;
      animation-delay: var(--delay, 0ms);
    }
    body.intro-play .intro-photo{
      animation: introPhoto 1100ms cubic-bezier(.2,.85,.2,1) forwards;
      animation-delay: var(--delay, 0ms);
    }
    @keyframes introFadeUp{
      from{ opacity:0; transform: translateY(18px); filter: blur(2px); }
      to{ opacity:1; transform: translateY(0); filter: blur(0); }
    }
    @keyframes introPhoto{
      from{ opacity:0; transform: translateY(18px) scale(1.02); filter: blur(4px); }
      to{ opacity:1; transform: translateY(0) scale(1.02); filter: blur(0); }
    }

    /* =====================================
       SCROLL REVEAL: scroll tới đâu hiện tới đó
       ===================================== */
    .reveal{
      opacity:0;
      transform: translateY(26px);
      transition: 900ms cubic-bezier(.2,.8,.2,1);
      will-change: transform, opacity;
    }
    .reveal.in{ opacity:1; transform: translateY(0); }
    .reveal.zoom{ transform: translateY(18px) scale(.985); }
    .reveal.zoom.in{ transform: translateY(0) scale(1); }
    .reveal.left{ transform: translateX(-18px); }
    .reveal.left.in{ transform: translateX(0); }
    .reveal.right{ transform: translateX(18px); }
    .reveal.right.in{ transform: translateX(0); }

    /* ===== Typography giống template ===== */
    .script-top{
      font-family: "Great Vibes", cursive;
      font-size: 44px;
      line-height: 1.1;
      margin: 10px 0 8px;
    }
    .names-script{
      font-family: "Alex Brush", cursive;
      font-size: 56px;
      line-height: 1;
      margin: 2px 0 10px;
    }
    .amp{ color: var(--blue); padding: 0 6px; display:inline-block; transform: translateY(-2px); }

    /* ===== HERO ===== */
    .hero{ padding-top: 24px; text-align:center; }
    .hero-meta{
      display:flex; justify-content:space-between; align-items:stretch;
      gap: 10px; margin: 18px 10px 16px;
      font-size: 13px; letter-spacing: .3px;
      text-transform: uppercase;
    }
    .hero-meta .cell{ flex:1; padding: 10px 8px; }
    .hero-meta .cell b{
      display:block; font-size: 14px; letter-spacing:.6px;
      color:#111; margin-bottom: 2px;
    }
    .hero-meta .vline{
      width: 2px; background: #111; opacity: .45;
      border-radius: 1px; margin: 10px 0;
    }
    .hero-photo{ width: 100%; overflow:hidden; margin-top: 6px; }
    .hero-photo img{
      width: 100%; display:block;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      transform: scale(1.02);
    }

    /* ===== Quote block ===== */
    .quote-date{
      font-family: "Cormorant Garamond", serif;
      font-size: 26px;
      margin: 16px 0 10px;
      letter-spacing:.3px;
    }
    .quote{
      font-style: italic;
      font-size: 16px;
      line-height: 1.75;
      margin: 0 auto;
      max-width: 360px;
    }

    /* ===== Envelope photo (phong bì xanh) ===== */
    .envelope{
      margin: 22px auto 0;
      width: min(92%, 360px);
      position: relative;
    }
    .env-top{
      height: 150px;
      background: var(--blue);
      border-radius: 18px;
      position: relative;
      overflow:hidden;
      box-shadow: var(--shadow2);
    }
    .env-top:before{
      content:"";
      position:absolute;
      left: 50%;
      bottom: -2px;
      transform: translateX(-50%);
      width: 0; height: 0;
      border-left: 190px solid transparent;
      border-right: 190px solid transparent;
      border-top: 130px solid rgba(255,255,255,.14);
      opacity: .75;
    }
    .env-photo{
      position:absolute;
      left: 50%;
      top: -46px;
      transform: translateX(-50%);
      width: 82%;
      border-radius: 10px;
      overflow:hidden;
      box-shadow: 0 12px 30px rgba(0,0,0,.14);
      border: 8px solid rgba(255,255,255,.6);
      background:#fff;
    }
    .env-photo img{
      width:100%;
      display:block;
      aspect-ratio: 16/10;
      object-fit: cover;
    }
    .wax{
      position:absolute;
      left: 50%;
      bottom: 14px;
      transform: translateX(-50%);
      width: 46px; height: 46px;
      border-radius: 999px;
      background: radial-gradient(circle at 30% 30%, #bfa06c, #7a5b2f);
      box-shadow: 0 10px 18px rgba(0,0,0,.18);
      display:grid; place-items:center;
      color:#2a1c0c;
      font-weight:800;
      font-size: 12px;
    }
    .wax:before{ content:"✿"; filter: drop-shadow(0 2px 0 rgba(255,255,255,.2)); }

    /* ===== Parents block ===== */
    .parents{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      padding-top: 6px;
    }
    .parents .col{ text-align:left; }
    .parents h3{
      font-family:"Cormorant Garamond", serif;
      font-size: 30px;
      margin: 0 0 10px;
      text-align:center;
      color:#111;
      font-weight: 600;
    }
    .parents p{ margin: 4px 0; font-size: 15px; color:#222; }
    .parents em{ display:block; margin-top: 6px; text-align:center; color:#555; }

    .serif-title{
      font-family: "Cormorant Garamond", serif;
      font-weight: 600;
      color: var(--blue);
      font-size: 38px;
      margin: 0;
      letter-spacing: .3px;
    }
    .and-olive{
      font-family: "Alex Brush", cursive;
      color: var(--olive);
      font-size: 28px;
      margin: 8px 0 -4px;
      transform: rotate(-2deg);
      display:inline-block;
    }

    /* ===== Event block big date ===== */
    .event-block{
      padding: 18px 8px 6px;
      text-align:center;
    }
    .event-block .subtitle{
      font-family:"Cormorant Garamond", serif;
      color: var(--blue);
      font-size: 36px;
      margin: 0 0 10px;
      font-weight: 600;
    }
    .event-block .time-line{
      font-family:"Cormorant Garamond", serif;
      font-size: 34px;
      letter-spacing: 1.2px;
      margin: 0 0 12px;
      color:#111;
      text-transform: uppercase;
    }
    .bigdate{
      display:flex;
      align-items:center;
      justify-content:center;
      gap: 12px;
      margin: 6px 0 8px;
    }
    .bigdate .side{
      width: 36%;
      max-width: 150px;
      font-family:"Cormorant Garamond", serif;
      font-size: 34px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color:#111;
      position:relative;
      padding: 10px 0;
    }
    .bigdate .side:before,
    .bigdate .side:after{
      content:"";
      position:absolute;
      left: 0; right: 0;
      height: 2px;
      background: repeating-linear-gradient(90deg, #111 0 4px, transparent 4px 8px);
      opacity: .55;
    }
    .bigdate .side:before{ top:0; }
    .bigdate .side:after{ bottom:0; }
    .bigdate .num{
      font-family:"Cormorant Garamond", serif;
      font-size: 88px;
      color: var(--blue);
      font-weight: 600;
      line-height: 1;
      width: 90px;
    }
    .lunar{
      font-size: 14px;
      color:#333;
      margin: 10px 0 16px;
      opacity: .9;
    }
    .place{
      font-family:"Cormorant Garamond", serif;
      font-size: 34px;
      color: var(--blue);
      margin: 0;
      text-transform: uppercase;
      font-weight: 600;
    }
    .place-sub{
      margin: 6px 0 0;
      color:#222;
      font-size: 16px;
    }

    /* ===== Paper timeline + icons ===== */
    .paper{
      background:
        radial-gradient(1200px 500px at 50% 0%, rgba(0,0,0,.06), transparent 60%),
        repeating-radial-gradient(circle at 20% 20%, rgba(0,0,0,.02) 0 2px, transparent 2px 8px),
        var(--paper);
      border-radius: 18px;
      padding: 24px 14px 14px;
      margin: 14px 0 0;
      box-shadow: 0 6px 20px rgba(0,0,0,.06);
    }
    .paper .script{
      font-family:"Alex Brush", cursive;
      color: var(--olive);
      font-size: 56px;
      margin: 0 0 8px;
      text-align:center;
      transform: rotate(-1deg);
    }
    .tl{
      display:grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 10px;
      margin-top: 8px;
      padding: 6px 0 12px;
    }
    .tl .item{ text-align:center; padding: 10px 6px; }
    .tl .time{
      font-size: 22px;
      margin: 10px 0 6px;
      color:#111;
      font-family:"Cormorant Garamond", serif;
      font-weight: 600;
    }
    .tl .label{ font-size: 16px; color:#222; }
    .sketch{
      width: 70px; height: 70px;
      margin: 0 auto;
      opacity:.92;
      filter: drop-shadow(0 2px 0 rgba(255,255,255,.7));
    }

    /* ===== Dresscode ===== */
    .dress{ margin-top: 14px; text-align:center; }
    .dress .script{
      font-family:"Alex Brush", cursive;
      color: var(--olive);
      font-size: 62px;
      margin: 2px 0 14px;
      transform: rotate(-1deg);
    }
    .dots{
      display:flex;
      justify-content:center;
      gap: 14px;
      padding-bottom: 10px;
    }
    .dot{
      width: 52px; height: 52px;
      border-radius: 999px;
      border: 3px solid rgba(0,0,0,.08);
      box-shadow: 0 10px 18px rgba(0,0,0,.08);
    }
    .dot.blue{ background: var(--blue); }
    .dot.black{ background:#2a2a2a; }
    .dot.cream{ background:#f5f2ea; }
    .dot.gray{ background:#cfcfcf; }

    /* ===== Note + balloon + couple photo + heart ===== */
    .note{
      font-size: 20px;
      line-height: 1.5;
      max-width: 360px;
      margin: 0 auto;
    }
    .balloon{
      position:absolute;
      right: 18px; top: 18px;
      width: 64px;
      transform: rotate(6deg);
      opacity:.95;
    }
    .photo-round{
      margin: 18px auto 10px;
      width: 100%;
      max-width: 390px;
      position: relative;
      border-radius: 26px;
      overflow:hidden;
      box-shadow: var(--shadow2);
      background:#ddd;
    }
    .photo-round img{
      width:100%;
      display:block;
      aspect-ratio: 4/3;
      object-fit: cover;
    }
    .heart-mid{
      position:absolute;
      left:50%;
      bottom: -10px;
      transform: translateX(-50%);
      width: 120px;
      height: 90px;
      background: #c22c2c;
      clip-path: path("M60 85 C60 85 10 58 10 30 C10 14 22 6 34 6 C45 6 55 14 60 22 C65 14 75 6 86 6 C98 6 110 14 110 30 C110 58 60 85 60 85 Z");
      filter: drop-shadow(0 10px 14px rgba(0,0,0,.18));
      opacity:.92;
    }
    .two-cols{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      align-items:start;
      margin-top: 12px;
    }
    .role{ font-family:"Alex Brush", cursive; font-size: 28px; margin: 6px 0 6px; }
    .person{
      font-family:"Cormorant Garamond", serif;
      font-size: 40px;
      margin: 4px 0 6px;
      color: var(--blue);
      font-weight: 600;
    }
    .dob{ color:#444; font-size: 15px; }

    /* ===== Story ===== */
    .story-title{
      font-family:"Alex Brush", cursive;
      font-size: 58px;
      margin: 12px 0 8px;
    }
    .story-body{
      text-align:left;
      max-width: 390px;
      margin: 0 auto;
      color:#4a4a4a;
      line-height: 1.85;
      font-size: 16px;
    }

    /* ===== Calendar + big photo + countdown ===== */
    .calendar-wrap{ position: relative; margin-top: 8px; }
    .calendar{
      width: 92%;
      margin: 0 auto;
      background: #f7f7f7;
      border-radius: 10px;
      padding: 10px 12px 12px;
      box-shadow: 0 10px 20px rgba(0,0,0,.08);
      transform: rotate(-1deg);
    }
    .calendar .month{
      text-align:right;
      font-family:"Alex Brush", cursive;
      color: var(--blue);
      font-size: 34px;
      margin-bottom: 4px;
    }
    .grid{
      display:grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 6px;
      font-size: 14px;
      color:#666;
      padding: 6px 4px 2px;
    }
    .day{
      height: 26px;
      display:grid; place-items:center;
      border-radius: 6px;
    }
    .hit{
      background: radial-gradient(circle at 40% 40%, rgba(220,20,60,.30), rgba(220,20,60,.08));
      color:#b0182f;
      font-weight: 800;
      position:relative;
    }
    .big-photo{
      margin: 12px auto 0;
      width: 92%;
      overflow:hidden;
    }
    .big-photo img{
      width: 100%;
      display:block;
      aspect-ratio: 3/4;
      object-fit: cover;
    }
    .count-title{
      font-family:"Alex Brush", cursive;
      font-size: 46px;
      margin: 12px 0 10px;
    }
    .count{
      display:flex;
      justify-content:center;
      gap: 12px;
      padding: 0 0 6px;
    }
    .cbox{
      width: 78px;
      background: var(--blue);
      color:#fff;
      border-radius: 10px;
      padding: 14px 10px 12px;
      box-shadow: var(--shadow2);
      text-align:center;
    }
    .cbox b{ display:block; font-size: 22px; margin-bottom: 4px; }
    .cbox span{ font-size: 16px; opacity:.95; }

    /* ===== Memories: frame + slider thumbs ===== */
    .mem-head{
      display:grid;
      grid-template-columns: 140px 1fr;
      gap: 14px;
      align-items:center;
      margin-top: 6px;
    }
    .frame{
      width: 140px;
      aspect-ratio: 1/1;
      border: 6px solid var(--blue);
      box-shadow: var(--shadow2);
      background:#fff;
      overflow:hidden;
    }
    .frame img{ width:100%; height:100%; object-fit:cover; display:block; }
    .mem-script{
      text-align:left;
      color: var(--blue);
      font-family:"Alex Brush", cursive;
      font-size: 44px;
      line-height: 1;
    }
    .mem-script small{
      display:block;
      font-size: 22px;
      color:#333;
      margin-left: 6px;
      font-family:"Cormorant Garamond", serif;
    }
    .slider{
      margin: 14px 0 0;
      border: 6px solid var(--blue);
      border-radius: 14px;
      overflow:hidden;
      box-shadow: var(--shadow2);
      background:#fff;
    }
    .slide-main{ position:relative; background:#ddd; }
    .slide-main img{
      width:100%;
      display:block;
      aspect-ratio: 16/10;
      object-fit: cover;
      border-radius: 10px;
      padding: 10px;
      background: #fff;
    }
    .arrow{
      position:absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 46px; height: 46px;
      border-radius: 999px;
      border:0;
      background: rgba(255,255,255,.85);
      box-shadow: 0 8px 16px rgba(0,0,0,.12);
      display:grid; place-items:center;
      cursor:pointer;
      font-size: 28px;
      color:#111;
    }
    .arrow.left{ left: 12px; }
    .arrow.right{ right: 12px; }
    .fullscreen{
      position:absolute;
      right: 16px; top: 16px;
      width: 36px; height: 36px;
      border-radius: 10px;
      border:0;
      background: rgba(255,255,255,.85);
      box-shadow: 0 8px 16px rgba(0,0,0,.12);
      cursor:pointer;
    }
    .thumbs{
      display:flex;
      gap: 8px;
      padding: 10px 10px 12px;
      overflow:auto;
      background:#f5f5f5;
    }
    .thumbs::-webkit-scrollbar{ height: 6px; }
    .thumbs::-webkit-scrollbar-thumb{ background: rgba(0,0,0,.18); border-radius: 99px; }
    .thumb{
      flex: 0 0 auto;
      width: 64px; height: 44px;
      border-radius: 8px;
      border: 2px solid transparent;
      overflow:hidden;
      cursor:pointer;
      background:#fff;
    }
    .thumb img{ width:100%; height:100%; object-fit:cover; display:block; }
    .thumb.active{ border-color: var(--blue); }

    /* ===== RSVP card ===== */
    .tip{
      color: #98a4c5;
      text-align:center;
      font-size: 18px;
      line-height: 1.7;
      max-width: 360px;
      margin: 0 auto 14px;
      font-family:"Cormorant Garamond", serif;
    }
    .card{
      background:#f3f1ea;
      border: 1px solid rgba(0,0,0,.08);
      box-shadow: var(--shadow2);
      border-radius: 10px;
